{
  "info": {
    "name": "Notification API - All Use Cases",
    "description": "Postman collection covering all use cases for /api/v1/register and /api/v1/notify",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "bcce103d-fc52-4a88-90d3-9578e9721b36"
    }
  ],
  "item": [
    {
      "name": "Register - POST /api/v1/register",
      "item": [
        {
          "name": "1. Success - Register with multiple types (type1, type2)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"notifications\": [\"type1\", \"type2\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "201 - User registered successfully"
          }
        },
        {
          "name": "2. Success - Register with single type",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d\",\n  \"notifications\": [\"type1\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "201 - User registered with single notification type"
          }
        },
        {
          "name": "3. Success - Register Category B (type4, type5)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"d4e5f6a7-b8c9-4d5e-9f0a-1b2c3d4e5f6a\",\n  \"notifications\": [\"type4\", \"type5\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "201 - User registered for Category B notifications"
          }
        },
        {
          "name": "4. 400 - Invalid notification type (INVALID_TYPE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"11111111-1111-1111-1111-111111111111\",\n  \"notifications\": [\"INVALID_TYPE\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "VAL-001 - Notification type not in enum"
          }
        },
        {
          "name": "5. 400 - Unsupported notification type (type7)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"11111111-1111-1111-1111-111111111111\",\n  \"notifications\": [\"type7\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "VAL-001 - type7 not in enum (type1-type6 only)"
          }
        },
        {
          "name": "6. 400 - Empty request body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "400 - Missing required fields"
          }
        },
        {
          "name": "7. 400 - Invalid UUID format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"11111111-1111-1111-1111-111111111111dddddd\",\n  \"notifications\": [\"type1\", \"type2\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "VAL-001 - Invalid userId format"
          }
        }
      ]
    },
    {
      "name": "Notify - POST /api/v1/notify",
      "item": [
        {
          "name": "1. Success - User subscribed (register first, then notify)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"notificationType\": \"type1\",\n  \"message\": \"Hello! Your notification is ready.\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "200 - Run Register first with same userId. User must be subscribed to type1."
          }
        },
        {
          "name": "2. Success - Category delivery (type1 subscribed, send type2)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"notificationType\": \"type2\",\n  \"message\": \"Category A delivery test\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "200 - User subscribed to type1 (Category A), receives type2 (same category)"
          }
        },
        {
          "name": "3. 404 - User not found",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"99999999-9999-9999-9999-999999999999\",\n  \"notificationType\": \"type1\",\n  \"message\": \"Test\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "USR-404 - User does not exist"
          }
        },
        {
          "name": "4. 403 - User not subscribed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"notificationType\": \"type4\",\n  \"message\": \"Test\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "USR-403 - User subscribed to type1 (Category A) but requesting type4 (Category B)"
          }
        },
        {
          "name": "5. 400 - Invalid notification type (type7)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"11111111-1111-1111-1111-111111111111\",\n  \"notificationType\": \"type7\",\n  \"message\": \"test\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "NOT-400 - type7 not in enum"
          }
        },
        {
          "name": "6. 400 - Invalid enum value (INVALID)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"11111111-1111-1111-1111-111111111111\",\n  \"notificationType\": \"INVALID\",\n  \"message\": \"test\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "NOT-400 - Invalid enum value"
          }
        },
        {
          "name": "7. 400 - Validation fails (null/missing fields)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": null,\n  \"notificationType\": null,\n  \"message\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "VAL-001 - Null userId, null notificationType, blank message"
          }
        },
        {
          "name": "8. 400 - Invalid UUID format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"11111111-1111-1111-1111-11111111111000\",\n  \"notificationType\": \"type1\",\n  \"message\": \"test\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "VAL-001 - Last segment has 14 chars instead of 12"
          }
        }
      ]
    },
    {
      "name": "Full Flow - Register then Notify",
      "item": [
        {
          "name": "Step 1 - Register user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": "if (pm.response.code === 201) { var j = pm.response.json(); if (j.data && j.data.userId) pm.collectionVariables.set('userId', j.data.userId); }",
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{$guid}}\",\n  \"notifications\": [\"type1\", \"type5\"]\n}"
            },
            "url": "{{baseUrl}}/api/v1/register",
            "description": "Registers user, stores userId in collection variable for Step 2"
          }
        },
        {
          "name": "Step 2 - Send notification to registered user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"notificationType\": \"type5\",\n  \"message\": \"Your app rocks!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/notify",
            "description": "Uses userId from Step 1. Run Step 1 first."
          }
        }
      ]
    }
  ]
}
